**/xsim.jou
**/xelab.log
**/xelab.pb
**/.xsim_*/
**/.xim_*/

# Vivado IP upgrade logs
ip_upgrade.log

# Vivado utility files
utils_1/

# Hardware export files (regenerated from project)
*.xsa

# =============================================================================
# Vitis Generated Files
# =============================================================================

# Build output directories
build/
export/

# Object files and dependency files
*.o
*.d

# Compiled binaries and images
*.elf
*.bin
*.pdi

# Boot image files (generated from FSBL + bitstream + app)
BOOT.BIN
FIRMWARE.BIN
BOOT.bif
FIRMWARE.bif

# Vitis workspace metadata
.vitisWorkspace.json
compile_commands.json

# Vitis IDE files
_ide/

# Vitis logs
logs/
*.log

# Vitis lock files
*.lock

# Vitis workspace generated content (use scripts/create_vitis_workspace.py to regenerate)
vitis_workspace/

# =============================================================================
# Bitstream Files
# =============================================================================
*.bit
*.ltx

# =============================================================================
# Local-Only Hardware References
# =============================================================================
/Datasheets/

# =============================================================================
# Miscellaneous
# =============================================================================

# Local agent/tool state
.claude/settings.local.json
.codex_tmp/
tclstore.wpc

# Vivado/Vitis PS summary output
NA/
1/

# Runtime log
dfx_runtime.txt
.Xil/
